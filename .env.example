# ──────────────────────────────────────────────────────────────
# Environment Variables for Data Vault
#
# Copy this file to .env before running the app:
#   cp .env.example .env
#
# These values are read by Django (via python-dotenv) and by
# Docker Compose (via the env_file directive in docker-compose.yml).
# ──────────────────────────────────────────────────────────────

# --- Django Settings ---

# Secret key for cryptographic signing (sessions, CSRF tokens, etc.)
# In production, generate a real key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-something-random

# Debug mode — shows detailed error pages in the browser.
# Set to False in production (never expose stack traces to users).
DJANGO_DEBUG=True

# Which hostnames Django will accept requests for.
# Add your domain here in production (e.g., datavault.example.com).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1


# --- PostgreSQL Database ---
# These values must match between Django and the Postgres container.
# The defaults below work out of the box for both Docker and local dev.

POSTGRES_DB=datavault
POSTGRES_USER=datavault
POSTGRES_PASSWORD=datavault
POSTGRES_PORT=5432

# POSTGRES_HOST is the one value you need to change between Docker and local:
#
#   Docker:   Use "db" — this is the service name in docker-compose.yml.
#             Docker's internal DNS automatically resolves "db" to the
#             Postgres container's IP address.
#
#   Local:    Use "localhost" — PostgreSQL is running directly on your
#             machine, so Django connects to it on localhost.
#
POSTGRES_HOST=db
